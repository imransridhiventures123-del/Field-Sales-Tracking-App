# FILE: .env (goes in root of project — same folder as package.json)
# OWNER: Imran
# IMPORTANT: Add .env to your .gitignore — never commit this to GitHub
#            Each developer has their own .env on their own machine

# Your backend API URL
# During development (before backend is built): keep as localhost:5000
# After Imran builds the Node.js backend: this stays the same
# After deployment to Render: change to your Render URL
VITE_API_URL=http://localhost:5000

# NOTE: All Vite env variables MUST start with VITE_
# to be accessible in your React code via import.meta.env.VITE_API_URL